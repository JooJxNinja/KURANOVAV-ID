local function isCharacterValid(char) return char and char.Parent and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health > 0 end

local function GetClosestPlayerSmart()
	local centerScreen = CenterDot.AbsolutePosition local closestTarget = nil local lowestScore = math.huge
	if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
	local myPos = LocalPlayer.Character.HumanoidRootPart.Position local listToScan = {}
	
	if State.AimbotTargetFilter == "Players" or State.AimbotTargetFilter == "All" then
		for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character and p.Character.Parent then table.insert(listToScan, p.Character) end end
	end
	
	if State.AimbotTargetFilter == "Bots" or State.AimbotTargetFilter == "All" then
		local PastaAi = workspace:FindFirstChild("Ai")
		if PastaAi then
			for _, obj in ipairs(PastaAi:GetChildren()) do
				if obj:IsA("Model") and obj ~= LocalPlayer.Character then
					local hum = obj:FindFirstChildOfClass("Humanoid")
					local hrp = obj:FindFirstChild("HumanoidRootPart")
					if hum and hrp and hum.Health > 0 then
						table.insert(listToScan, obj)
					end
				end
			end
		end
	end
	
	for _, char in ipairs(listToScan) do
		if char and char.Parent then
			local hrp = char:FindFirstChild("HumanoidRootPart") local hum = char:FindFirstChildOfClass("Humanoid")
			if hrp and hum and hum.Health > 0 then
				local targetPart = char:FindFirstChild("Head") or hrp
				local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
				if onScreen then
					local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
					if distToCenter < State.FovRadiusValue then
						local distInStuds = (targetPart.Position - myPos).Magnitude
						local score = (distToCenter * 0.7) + (distInStuds * 0.3)
						if score < lowestScore then lowestScore = score closestTarget = char end
					end
				end
			end
		end
	end
	return closestTarget
end

local function ApplyHighlightToTarget(targetChar)
	if CurrentTargetHighlight and CurrentTargetHighlight.Parent then if CurrentTargetHighlight.Adornee == targetChar then return end CurrentTargetHighlight:Destroy() end
	if targetChar and targetChar.Parent then
		local hl = Instance.new("Highlight", targetChar) hl.Name = "AimbotTargetHighlight" hl.FillTransparency = 0.7 hl.OutlineTransparency = 0 hl.Adornee = targetChar CurrentTargetHighlight = hl
	end
end

RunService.RenderStepped:Connect(function()
	local h = (tick() % 5) / 5 local rainbow = Color3.fromHSV(h, 0.9, 0.9)
	if CurrentTargetHighlight and CurrentTargetHighlight.Parent then CurrentTargetHighlight.OutlineColor = rainbow CurrentTargetHighlight.FillColor = rainbow end
	if State.AimbotSystemActive then
		local scanTarget = GetClosestPlayerSmart()
		if State.AimbotLockActive then
			if State.AimbotMode == "100% Focus" then
				if not CurrentAimbotTarget or not isCharacterValid(CurrentAimbotTarget) then
					CurrentAimbotTarget = scanTarget
				end
				if CurrentAimbotTarget and isCharacterValid(CurrentAimbotTarget) then
					ApplyHighlightToTarget(CurrentAimbotTarget)
					local targetPos = CurrentAimbotTarget:FindFirstChild("Head") and CurrentAimbotTarget.Head.Position or CurrentAimbotTarget.HumanoidRootPart.Position
					Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
				else
					CurrentAimbotTarget = nil if CurrentTargetHighlight then CurrentTargetHighlight:Destroy() CurrentTargetHighlight = nil end
					State.AimbotLockActive = false FloatAimbotButton.Text = "Aim\nOFF" FloatAimbotButton.BackgroundColor3 = Color3.fromRGB(130, 20, 30)
				end
			elseif State.AimbotMode == "Dynamic" then
				if scanTarget and isCharacterValid(scanTarget) then
					CurrentAimbotTarget = scanTarget ApplyHighlightToTarget(scanTarget)
					local targetPos = scanTarget:FindFirstChild("Head") and scanTarget.Head.Position or scanTarget.HumanoidRootPart.Position
					Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
				else
					CurrentAimbotTarget = nil if CurrentTargetHighlight then CurrentTargetHighlight:Destroy() CurrentTargetHighlight = nil end
					State.AimbotLockActive = false FloatAimbotButton.Text = "Aim\nOFF" FloatAimbotButton.BackgroundColor3 = Color3.fromRGB(130, 20, 30)
				end
			end
		else
			if scanTarget and isCharacterValid(scanTarget) then ApplyHighlightToTarget(scanTarget) else if CurrentTargetHighlight then CurrentTargetHighlight:Destroy() CurrentTargetHighlight = nil end end
			CurrentAimbotTarget = nil
		end
	else
		if CurrentTargetHighlight then CurrentTargetHighlight:Destroy() CurrentTargetHighlight = nil end CurrentAimbotTarget = nil
	end
end)

