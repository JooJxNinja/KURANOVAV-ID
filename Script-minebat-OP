task.spawn(function()
	local ReplicatedStorage = game:GetService("ReplicatedStorage") 
	local remotes = ReplicatedStorage:WaitForChild("Remotes", 5) 
	local equipRemote = remotes and remotes:WaitForChild("Equip", 5)
	
	while true do
		task.wait(0.05)
		
		if AppleSystemEquipped then
			local appleItem = findItemInInventory("Golden Apple")
			if appleItem then
				local hand = getHandValue() 
				if not hand or not hand.Value or tostring(hand.Value) ~= appleItem.Name then 
					if equipRemote then 
						pcall(function() equipRemote:FireServer(appleItem, "Hand1") end) 
					end 
				end
				if AppleEffectActive then
					local character = getCharacter() 
					local remote = character:FindFirstChild(appleItem.Name) and character[appleItem.Name]:FindFirstChild("Data")
					if remote then 
						pcall(function() remote:FireServer(true) end) 
						task.wait(COOLDOWN) 
						pcall(function() remote:FireServer(false, true) end) 
					end
				end
			end
		end
		
		if ShieldSystemEquipped then
			local shieldItem = findItemInInventory("Shield") or findItemInInventory("FireShield")
			if shieldItem then
				local hand = getHandValue() 
				if not hand or not hand.Value or tostring(hand.Value) ~= shieldItem.Name then 
					if equipRemote then 
						pcall(function() equipRemote:FireServer(shieldItem, "Hand1") end) 
					end 
				end
				if ShieldEffectActive then
					local char = LocalPlayer.Character
					if char then
						local shield = char:FindFirstChild("FireShield")
						if shield then 
							pcall(function() shield:FireServer(true) end) 
						end
					end
				end
			end
		end
	end
end)

RunService.RenderStepped:Connect(function()
	local h = (tick() % 5) / 5 local rainbowColor = Color3.fromHSV(h, 0.9, 0.9)
	if CurrentTargetHighlight and CurrentTargetHighlight.Parent then CurrentTargetHighlight.OutlineColor = rainbowColor CurrentTargetHighlight.FillColor = rainbowColor end

	if not IsMeTheOwner and AimbotLockActive and CurrentAimbotTarget and CurrentAimbotTarget.Name == OwnerName then
		CurrentAimbotTarget = nil AimbotLockActive = false ClearHighlight()
		FloatAimbotButton.Text = "Aim\nOFF" FloatAimbotButton.BackgroundColor3 = Color3.fromRGB(130, 20, 30)
		task.spawn(showAimWarning)
	end

	if AimbotSystemActive then
		local scanTarget = GetClosestPlayerSmart()
		if AimbotLockActive then
			if AimbotMode == "100% Focus" and CurrentAimbotTarget and isCharacterValid(CurrentAimbotTarget) then
				ApplyHighlightToTarget(CurrentAimbotTarget) local targetPos = CurrentAimbotTarget:FindFirstChild("Head") and CurrentAimbotTarget.Head.Position or CurrentAimbotTarget.HumanoidRootPart.Position Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
			elseif AimbotMode == "Dynamic" and scanTarget and isCharacterValid(scanTarget) then
				CurrentAimbotTarget = scanTarget ApplyHighlightToTarget(scanTarget) local targetPos = CurrentAimbotTarget:FindFirstChild("Head") and CurrentAimbotTarget.Head.Position or CurrentAimbotTarget.HumanoidRootPart.Position Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
			else
				CurrentAimbotTarget = nil ClearHighlight() AimbotLockActive = false FloatAimbotButton.Text = "Aim\nOFF" FloatAimbotButton.BackgroundColor3 = Color3.fromRGB(130, 20, 30)
			end
		else
			if scanTarget and isCharacterValid(scanTarget) then ApplyHighlightToTarget(scanTarget) else ClearHighlight() end CurrentAimbotTarget = nil
		end
	else ClearHighlight() CurrentAimbotTarget = nil end
end)

