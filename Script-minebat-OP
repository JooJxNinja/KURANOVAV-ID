local function GetClosestPlayerSmart()
	local centerScreen = CenterDot.AbsolutePosition local closestTarget = nil local lowestScore = math.huge
	if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
	local myPos = LocalPlayer.Character.HumanoidRootPart.Position

	local listToScan = {}
	if AimbotTargetFilter == "Players" then
		for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then table.insert(listToScan, p.Character) end end
	elseif AimbotTargetFilter == "Bots" then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) and obj ~= LocalPlayer.Character then table.insert(listToScan, obj) end
		end
	else
		for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer and p.Character then table.insert(listToScan, p.Character) end end
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") and not Players:GetPlayerFromCharacter(obj) and obj ~= LocalPlayer.Character then table.insert(listToScan, obj) end
		end
	end

	for _, char in ipairs(listToScan) do
		-- Se NÃO for você rodando o script, a trava bloqueia mirar em você
		if not IsMeTheOwner then
			if char.Name == OwnerName then continue end
			local pObj = Players:GetPlayerFromCharacter(char)
			if pObj and pObj.Name == OwnerName then continue end
		end
		
		local hrp = char:FindFirstChild("HumanoidRootPart") local hum = char:FindFirstChildOfClass("Humanoid")
		if hrp and hum and hum.Health > 0 then
			local targetPart = char:FindFirstChild("Head") or hrp
			local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
			if onScreen then
				local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
				if distanceToCenter < FovRadiusValue then
					local distanceInStuds = (targetPart.Position - myPos).Magnitude
					local score = (distanceToCenter * 0.7) + (distanceInStuds * 0.3)
					if score < lowestScore then lowestScore = score closestTarget = char end
				end
			end
		end
	end
	return closestTarget
end

local function ApplyHighlightToTarget(targetChar)
	if CurrentTargetHighlight and CurrentTargetHighlight.Parent then if CurrentTargetHighlight.Adornee == targetChar then return end CurrentTargetHighlight:Destroy() end
	if targetChar then
		local hl = Instance.new("Highlight") hl.Name = "AimbotTargetHighlight" hl.FillTransparency = 0.7 hl.OutlineTransparency = 0 hl.Adornee = targetChar hl.Parent = targetChar CurrentTargetHighlight = hl
	end
end

local function ClearHighlight() if CurrentTargetHighlight then CurrentTargetHighlight:Destroy() CurrentTargetHighlight = nil end end
local function isCharacterValid(char) return char and char.Parent and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health > 0 end

