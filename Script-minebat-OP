local function SaveSettings()
	local settingsTable = {
		TargetValueSpeed = TargetValueSpeed,
		SpeedActive = SpeedActive,
		InfiniteJumpActive = InfiniteJumpActive,
		NoclipActive = NoclipActive,
		AimbotSystemActive = AimbotSystemActive,
		FovRadiusValue = FovRadiusValue,
		AimbotMode = AimbotMode,
		AimbotTargetFilter = AimbotTargetFilter
	}
	
	pcall(function()
		if writefile then
			local json = HttpService:JSONEncode(settingsTable)
			writefile(ConfigFileName, json)
		end
	end)
end

local function LoadSettings()
	pcall(function()
		if isfile and isfile(ConfigFileName) and readfile then
			local json = readfile(ConfigFileName)
			local settingsTable = HttpService:JSONDecode(json)
			if settingsTable then
				if settingsTable.TargetValueSpeed ~= nil then TargetValueSpeed = settingsTable.TargetValueSpeed end
