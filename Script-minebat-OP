local function LoadConfig()
	if isfile(ConfigName) then
		local success, content = pcall(function() return readfile(ConfigName) end)
		if success then
			local success2, data = pcall(function() return HttpService:JSONDecode(content) end)
			if success2 and data then
				for k, v in pairs(data) do
					if type(v) == "table" and k == "Keybinds" then
						for bindK, bindV in pairs(v) do State.Keybinds[bindK] = bindV end
					else
						State[k] = v
					end
				end
			end
		end
	end
end
