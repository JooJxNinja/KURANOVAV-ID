local function Translate(text)
	if UserLang == "pt" then return text end
	if not text or text == "" then return text end
	
	if string.match(text, "^[:;xX=]['%-]?([3%)(%]%[%D])+$") or string.match(text, "^%b{}") then
		return text
	end

	local translatedText = text
	local success = pcall(function()
		local encodedText = HttpService:UrlEncode(text)
		local url = string.format("https://translate.googleapis.com/translate_a/single?client=gtx&sl=pt&tl=%s&dt=t&q=%s", UserLang, encodedText)
		
		local req = (syn and syn.request) or (http and http.request) or request
		if req then
			local res = req({Url = url, Method = "GET"})
			if res.StatusCode == 200 then
				local data = HttpService:JSONDecode(res.Body)
				if data and data[1] and data[1][1] and data[1][1][1] then
					translatedText = data[1][1][1]
				end
			end
		end
	end)
	
	return success and translatedText or text
end

