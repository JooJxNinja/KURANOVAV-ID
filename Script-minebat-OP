				if settingsTable.FovRadiusValue ~= nil then FovRadiusValue = settingsTable.FovRadiusValue end
				if settingsTable.AimbotMode ~= nil then AimbotMode = settingsTable.AimbotMode end
				if settingsTable.AimbotTargetFilter ~= nil then AimbotTargetFilter = settingsTable.AimbotTargetFilter end
			end
		end
	end)
end

